<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:l="sap.ui.layout">
	<Dialog class="sapUiSizeCompact" stretch="{device>/system/phone}" draggable="true" resizable="true">
		<customHeader>
			<Bar>
				<contentMiddle>
					<Label text="Response"/>
				</contentMiddle>
			</Bar>
		</customHeader>
		<content>
			<VBox>
				<Text text="{jsonModel>/temNOTES}"/>
			</VBox>
		</content>
		<endButton>
			<Button type="Transparent" text="{i18n>Cancel}" press="onClose"/>
		</endButton>
	</Dialog>
</core:FragmentDefinition>